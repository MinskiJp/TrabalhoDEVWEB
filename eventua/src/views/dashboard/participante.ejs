<%- include('../partials/head', { titulo: 'Painel' }) %>
<%- include('../partials/navbar') %>
<main>
  <div class="container">
    <% const ativas = inscricoes.filter(i => i.status === 'confirmada'); %>
    <div class="dash-head">
      <span class="eyebrow">Bem-vindo de volta</span>
      <h1><%= usuario.nome %></h1>
    </div>

    <div class="stats">
      <div class="stat"><div class="n"><%= ativas.length %></div><div class="l">Inscricoes ativas</div></div>
      <div class="stat"><div class="n"><%= inscricoes.length %></div><div class="l">Total no historico</div></div>
    </div>

    <div class="section-head"><h2>Minhas inscricoes</h2></div>

    <% if (inscricoes.length === 0) { %>
      <div class="empty">
        <div class="serif">Voce ainda nao se inscreveu em nenhum evento</div>
        <p><a href="/eventos" class="muted">Explorar eventos &rarr;</a></p>
      </div>
    <% } else { %>
      <% inscricoes.forEach(insc => { %>
        <% if (insc.evento) { %>
          <div class="list-row">
            <div>
              <div class="title"><%= insc.evento.titulo %></div>
              <div class="when"><%= insc.evento.data %> · <%= insc.evento.local %></div>
            </div>
            <div class="right">
              <span class="badge <%= insc.status === 'confirmada' ? 'badge-ok' : 'badge-no' %>"><%= insc.status %></span>
              <% if (insc.status === 'confirmada') { %>
                <form action="/inscricoes/<%= insc.id %>/cancelar" method="POST">
                  <button class="btn btn-danger btn-sm" type="submit">Cancelar</button>
                </form>
              <% } %>
            </div>
          </div>
        <% } %>
      <% }) %>
    <% } %>
  </div>
</main>
<%- include('../partials/footer') %>
